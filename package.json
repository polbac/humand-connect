{
  "name": "humand-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Humand API - Users Module",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "humand-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next lint && tsc --noEmit",
    "lint": "next lint",
    "build:mcp": "tsc",
    "start:mcp": "node dist/index.js",
    "dev:mcp": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "humand",
    "api",
    "cursor",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "dotenv": "^17.3.1",
    "mcp-handler": "^1.0.7",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
